# ───────────── PostgreSQL ─────────────
POSTGRES_DB=compvideo
POSTGRES_USER=cvs
POSTGRES_PASSWORD=cvs_secret

# ───────────── MinIO / S3 ─────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_BUCKET=videos
# Public URL видимый браузеру для presigned URLs (при продакшн — заменить на реальный endpoint)
S3_PUBLIC_URL=http://localhost:9000

# ───────────── Backend ─────────────
BACKEND_PORT=8080
JWT_SECRET=change_me_in_production_use_random_32_chars

# ───────────── Frontend ─────────────
VITE_API_BASE_URL=http://localhost:8080

# ───────────── CORS ─────────────
CORS_ORIGINS=http://localhost:5173
